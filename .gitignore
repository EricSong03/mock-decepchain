# Generated artifacts and trained weights — keep local (DUAL-USE guardrail:
# the backdoored adapters and triggered dataset must NOT be committed/pushed).
# Anchored to repo root so they don't catch source dirs like src/data/.
/data/
/checkpoints/
/runs/
/wandb/
*.pt
*.bin
*.safetensors
# docs/ is intentionally tracked: it carries the run notes the next session needs
# (results / problems / decisions). It contains text only — no weights or dataset.

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.eggs/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

